#!/bin/bash

set -euo pipefail

# Load .env if present (local development)
if [ -f .env ]; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
fi

FIRST_WEEK_IS_EVEN=1 # flip this if the bot is creating RC on the wrong weeks

DAY_OF_WEEK=$(date +%u) # 5 = Friday
WEEK_NUMBER=$(date +%V | sed 's/^0*//' | tr -d '[:space:]')

if [ "$DAY_OF_WEEK" != "5" ]; then
  echo "Not RC creation day (not Friday)."
  exit 0
fi

IS_FIRST_WEEK=0
if [ "$FIRST_WEEK_IS_EVEN" = "1" ] && [ $(( WEEK_NUMBER % 2 )) -eq 0 ]; then
  IS_FIRST_WEEK=1
elif [ "$FIRST_WEEK_IS_EVEN" = "0" ] && [ $(( WEEK_NUMBER % 2 )) -ne 0 ]; then
  IS_FIRST_WEEK=1
fi

if [ "$IS_FIRST_WEEK" != "1" ]; then
  echo "Not RC creation day (not first week of cadence)."
  exit 0
fi

github() {
  curl -sf \
    -H "Authorization: Bearer $GITHUB_TOKEN" \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2022-11-28" \
    -H "Content-Type: application/json" \
    "$@"
}

echo "Fetching version from eigen's app.json..."
VERSION=$(github "https://api.github.com/repos/artsy/eigen/contents/app.json?ref=main" \
  | jq -r '.content' | tr -d '\n' | base64 -d | jq -r '.version // .expo.version')

if [ -z "$VERSION" ] || [ "$VERSION" = "null" ]; then
  echo "Error: Could not find version in app.json"
  exit 1
fi

BRANCH_NAME="rc-v${VERSION}"
echo "Creating RC branch: $BRANCH_NAME"

SHA=$(github "https://api.github.com/repos/artsy/eigen/git/ref/heads/main" \
  | jq -r '.object.sha')

github -X POST "https://api.github.com/repos/artsy/eigen/git/refs" \
  -d "$(jq -n --arg branch "refs/heads/$BRANCH_NAME" --arg sha "$SHA" \
    '{ref: $branch, sha: $sha}')"

TREE_SHA=$(github "https://api.github.com/repos/artsy/eigen/git/commits/$SHA" \
  | jq -r '.tree.sha')

EMPTY_COMMIT_SHA=$(github -X POST "https://api.github.com/repos/artsy/eigen/git/commits" \
  -d "$(jq -n --arg msg "chore: open release candidate $VERSION" --arg tree "$TREE_SHA" --arg parent "$SHA" \
    '{message: $msg, tree: $tree, parents: [$parent]}')" \
  | jq -r '.sha')

github -X PATCH "https://api.github.com/repos/artsy/eigen/git/refs/heads/$BRANCH_NAME" \
  -d "$(jq -n --arg sha "$EMPTY_COMMIT_SHA" '{sha: $sha}')" > /dev/null

PR_RESPONSE=$(github -X POST "https://api.github.com/repos/artsy/eigen/pulls" \
  -d "$(jq -n \
    --arg version "$VERSION" \
    --arg branch "$BRANCH_NAME" \
    '{
      title: "chore(release): v\($version) RC",
      head: $branch,
      base: "main",
      body: "## Release Candidate \($version)\n\nThis branch was automatically created as the release candidate for version \($version).\n\n> ⚠️ Do not merge this PR. It is used for tracking the release and 🍒 cherry-picking fixes only.\n\n#nochangelog"
    }')")

PR_NUMBER=$(echo "$PR_RESPONSE" | jq -r '.number')
PR_URL=$(echo "$PR_RESPONSE" | jq -r '.html_url')

github -X POST "https://api.github.com/repos/artsy/eigen/issues/$PR_NUMBER/labels" \
  -d '{"labels": ["Do not merge"]}' > /dev/null

curl -sf -X POST \
  -H "Authorization: Bearer $SLACK_TOKEN" \
  -H "Content-Type: application/json" \
  "https://slack.com/api/chat.postMessage" \
  -d "$(jq -n \
    --arg channel "$SLACK_CHANNEL" \
    --arg text "🥶🥶 Code freeze Release candidate branch \`$BRANCH_NAME\` has been created in eigen! PR: $PR_URL" \
    '{channel: $channel, text: $text}')" > /dev/null

echo "Successfully created RC branch $BRANCH_NAME and PR #$PR_NUMBER"
